{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate && prisma generate --schema prisma/sqlite/schema.prisma && prisma generate --schema prisma/mysql/schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:migrate:sqlite": "prisma migrate dev --schema prisma/sqlite/schema.prisma",
    "db:migrate:mysql": "prisma migrate dev --schema prisma/mysql/schema.prisma",
    "db:seed": "node prisma/seed.js",
    "ci:full": "npm run lint && npm run typecheck && npm run test && npm run build",
    "smoke:shop": "node scripts/smoke-shop-flow.js",
    "smoke:bp": "node scripts/smoke-business-processes.js --cleanup"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "@supabase/supabase-js": "^2.45.4",
    "framer-motion": "^12.29.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sanitize-html": "^2.17.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
