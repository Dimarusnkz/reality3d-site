NODE_ENV="production"
PORT="3001"

DB_PROVIDER="postgres" # sqlite, mysql, postgres

DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/reality3d?schema=public"
DATABASE_URL_SQLITE="file:./dev.db"
DATABASE_URL_MYSQL="mysql://USER:PASSWORD@127.0.0.1:3306/reality3d"

SESSION_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Site URL (required for payment callbacks)
NEXT_PUBLIC_SITE_URL="https://www.reality3d.ru"

# TBank acquiring
TBANK_TERMINAL_KEY=""
TBANK_PASSWORD=""

# Warehouse notifications (optional)
WAREHOUSE_LOW_STOCK_EMAILS="manager@reality3d.ru,warehouse@reality3d.ru"
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@reality3d.ru"

# Finance notifications + cron (optional)
FINANCE_DISCREPANCY_EMAILS="admin@reality3d.ru,accountant@reality3d.ru"
CRON_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET"

NEXT_PUBLIC_TURNSTILE_ENABLED="false"
TURNSTILE_ENABLED="false"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x..."
TURNSTILE_SECRET_KEY="0x..."

TELEGRAM_BOT_TOKEN=""
MAX_BOT_TOKEN=""

SEED_ADMIN_EMAIL="admin@reality3d.local"
SEED_ADMIN_PASSWORD="CHANGE_ME"
