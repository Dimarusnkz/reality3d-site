// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String        // Хэш пароля
  name         String?
  role         String        @default("user") // admin, user, engineer, manager, warehouse, delivery
  phone        String?       // Телефон
  address      String?       // Адрес доставки
  tokenVersion Int           @default(0)
  createdAt    DateTime      @default(now())
  orders       Order[]
  assignedOrders Order[]     @relation("OrderAssignee")
  chatSessions ChatSession[] // Чаты пользователя (как клиента)
  messages     ChatMessage[] // Сообщения, отправленные пользователем
  comments     OrderComment[] // Комментарии к заказам
  reviews      Review[]       // Отзывы пользователя
  articles     Article[]      // Статьи автора
  sessions     Session[]
  auditEvents  AuditEvent[]   @relation("AuditActor")
  shopWishlistItems ShopWishlistItem[]
  shopCart     ShopCart?
  shopOrders   ShopOrder[]
  shopWarehouseLogs ShopWarehouseLog[]
  shopClientLogs ShopClientLog[]
}

model Session {
  id         String   @id @default(uuid())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  ipHash     String?
  userAgent  String?

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model AuditEvent {
  id          String   @id @default(uuid())
  actorUserId Int?
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  action      String
  target      String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorUserId, createdAt])
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    Int
  author      User     @relation(fields: [authorId], references: [id])
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  rating    Int      // 1-5
  text      String
  photos    String?  // JSON массив ссылок на фото
  status    String   @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id        Int          @id @default(autoincrement())
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  title     String?      // Short description/name of the order
  status    String       @default("pending") // "pending", "processing", "completed", "paid", "shipped"
  details   String?      // JSON or text description
  price     Float?
  deadline  DateTime?    // Expected completion date
  assignedToId Int?      // Employee assigned to this order
  assignedTo   User?     @relation("OrderAssignee", fields: [assignedToId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt @default(now())
  chat      ChatSession? // Связанный чат заказа
  comments  OrderComment[]
}

model OrderComment {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

model ChatSession {
  id        Int           @id @default(autoincrement())
  userId    Int
  user      User          @relation(fields: [userId], references: [id])
  orderId   Int?          @unique
  order     Order?        @relation(fields: [orderId], references: [id])
  status    String        @default("active") // "active", "archived"
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id          Int         @id @default(autoincrement())
  sessionId   Int
  session     ChatSession @relation(fields: [sessionId], references: [id])
  senderId    Int?        // Null для системных сообщений
  sender      User?       @relation(fields: [senderId], references: [id])
  content     String
  isInternal  Boolean     @default(false) // true = скрыто от клиента (для общения команды)
  attachments String?     // JSON массив ссылок на файлы
  read        Boolean     @default(false)
  createdAt   DateTime    @default(now())
}

model TelegramSubscriber {
  id        Int      @id @default(autoincrement())
  chatId    String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model MaxSubscriber {
  id        Int      @id @default(autoincrement())
  chatId    String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model ShopCategory {
  id        Int            @id @default(autoincrement())
  name      String
  slug      String         @unique
  parentId  Int?
  parent    ShopCategory?  @relation("ShopCategoryParent", fields: [parentId], references: [id])
  children  ShopCategory[] @relation("ShopCategoryParent")
  products  ShopProduct[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ShopProduct {
  id               Int                @id @default(autoincrement())
  name             String
  slug             String             @unique
  sku              String?
  description      String?
  shortDescription String?
  priceKopeks      Int
  compareAtKopeks  Int?
  stock            Int                @default(0)
  isActive         Boolean            @default(true)
  categoryId       Int?
  category         ShopCategory?      @relation(fields: [categoryId], references: [id])
  images           ShopProductImage[]
  wishlistItems    ShopWishlistItem[]
  cartItems        ShopCartItem[]
  orderItems       ShopOrderItem[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([isActive, priceKopeks])
  @@index([categoryId])
}

model ShopProductImage {
  id        Int         @id @default(autoincrement())
  productId Int
  product   ShopProduct @relation(fields: [productId], references: [id])
  url       String
  alt       String?
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([productId, sortOrder])
}

model ShopWishlistItem {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id])
  productId Int
  product   ShopProduct @relation(fields: [productId], references: [id])
  createdAt DateTime    @default(now())

  @@unique([userId, productId])
  @@index([productId])
}

model ShopCart {
  id        String         @id @default(uuid())
  userId    Int            @unique
  user      User           @relation(fields: [userId], references: [id])
  items     ShopCartItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ShopCartItem {
  id              String      @id @default(uuid())
  cartId          String
  cart            ShopCart    @relation(fields: [cartId], references: [id])
  productId       Int
  product         ShopProduct @relation(fields: [productId], references: [id])
  quantity        Int         @default(1)
  unitPriceKopeks Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([cartId, productId])
  @@index([productId])
}

model ShopOrder {
  id                 String          @id @default(uuid())
  orderNo            Int             @unique @default(autoincrement())
  userId             Int?
  user               User?           @relation(fields: [userId], references: [id])
  status             String          @default("pending")
  paymentStatus      String          @default("unpaid")
  paymentProvider    String?
  shippingMethod     String          @default("pickup")
  shippingCostKopeks Int             @default(0)
  totalKopeks        Int             @default(0)
  contactName        String?
  contactPhone       String?
  contactEmail       String?
  deliveryCity       String?
  deliveryAddress    String?
  deliveryPostalCode String?
  comment            String?
  items              ShopOrderItem[]
  payments           ShopPayment[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ShopOrderItem {
  id              String      @id @default(uuid())
  orderId         String
  order           ShopOrder   @relation(fields: [orderId], references: [id])
  productId       Int?
  product         ShopProduct? @relation(fields: [productId], references: [id])
  productName     String
  sku             String?
  quantity        Int
  unitPriceKopeks Int
  totalKopeks     Int
  createdAt       DateTime    @default(now())

  @@index([orderId])
}

model ShopPayment {
  id                String    @id @default(uuid())
  orderId           String
  order             ShopOrder @relation(fields: [orderId], references: [id])
  provider          String
  status            String    @default("pending")
  amountKopeks      Int
  currency          String    @default("RUB")
  externalPaymentId String?
  paymentUrl        String?
  rawPayload        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([provider, status, createdAt])
  @@index([externalPaymentId])
}

model ShopInventoryItem {
  id           Int        @id @default(autoincrement())
  productId    Int        @unique
  product      ShopProduct @relation(fields: [productId], references: [id])
  unit         String     @default("pcs")
  quantity     Decimal    @default(0) @db.Decimal(18, 3)
  minThreshold Decimal    @default(0) @db.Decimal(18, 3)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([unit])
  @@index([quantity])
}

model ShopWarehouseLog {
  id            String      @id @default(uuid())
  createdAt     DateTime    @default(now())
  actorUserId   Int?
  actor         User?       @relation(fields: [actorUserId], references: [id])
  actorRole     String?
  actionType    String
  reason        String?
  productId     Int?
  product       ShopProduct? @relation(fields: [productId], references: [id])
  sku           String?
  productName   String?
  quantityDelta Decimal     @db.Decimal(18, 3)
  unit          String
  shopOrderId   String?
  shopOrder     ShopOrder?  @relation(fields: [shopOrderId], references: [id])
  serviceOrderId Int?
  serviceOrder  Order?      @relation(fields: [serviceOrderId], references: [id])
  supplier      String?
  documentNo    String?
  comment       String?
  ipHash        String?
  userAgent     String?

  @@index([createdAt])
  @@index([actorRole, createdAt])
  @@index([actionType, createdAt])
  @@index([productId, createdAt])
  @@index([shopOrderId])
}

model ShopClientLog {
  id         String      @id @default(uuid())
  createdAt  DateTime    @default(now())
  userId     Int?
  user       User?       @relation(fields: [userId], references: [id])
  actionType String
  productId  Int?
  product    ShopProduct? @relation(fields: [productId], references: [id])
  shopOrderId String?
  shopOrder  ShopOrder?  @relation(fields: [shopOrderId], references: [id])
  quantity   Decimal?    @db.Decimal(18, 3)
  unit       String?
  orderStatus String?
  ipHash     String?
  userAgent  String?
  message    String?

  @@index([createdAt])
  @@index([actionType, createdAt])
  @@index([userId, createdAt])
  @@index([productId, createdAt])
  @@index([shopOrderId, createdAt])
}
