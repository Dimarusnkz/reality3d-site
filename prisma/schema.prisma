generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          Int                        @id @default(autoincrement())
  email                       String                     @unique
  password                    String
  name                        String?
  role                        String                     @default("user")
  createdAt                   DateTime                   @default(now())
  phone                       String?
  address                     String?
  tokenVersion                Int                        @default(0)
  city                        String?
  passwordResetToken          String?                    @unique
  passwordResetExpires        DateTime?
  createdGroups               AccessGroup[]              @relation("AccessGroupCreator")
  articles                    Article[]
  cashEntries                 CashEntry[]
  cashReconciliations         CashReconciliation[]
  messages                    ChatMessage[]
  chatSessions                ChatSession[]
  assignedOrders              Order[]                    @relation("OrderAssignee")
  orders                      Order[]
  comments                    OrderComment[]
  reviews                     Review[]
  shopCart                    ShopCart?
  shopClientLogs              ShopClientLog[]
  shopOrders                  ShopOrder[]
  shopWarehouseLogs           ShopWarehouseLog[]
  shopWishlistItems           ShopWishlistItem[]
  accessGroups                UserAccessGroup[]
  accessPermissions           UserAccessPermission[]
  warehouseInventoriesCreated WarehouseInventoryCount[]  @relation("WarehouseInventoryCreator")
  warehouseInventoriesPosted  WarehouseInventoryCount[]  @relation("WarehouseInventoryPoster")
  warehouseProductionCreated  WarehouseProductionOrder[] @relation("WarehouseProductionCreator")
  warehouseProductionPosted   WarehouseProductionOrder[] @relation("WarehouseProductionPoster")
  warehouseReceiptsCreated    WarehouseReceipt[]         @relation("WarehouseReceiptCreator")
  warehouseReceiptsPosted     WarehouseReceipt[]         @relation("WarehouseReceiptPoster")
  warehouseTransfersCreated   WarehouseTransfer[]        @relation("WarehouseTransferCreator")
  warehouseTransfersPosted    WarehouseTransfer[]        @relation("WarehouseTransferPoster")
  warehousePurchaseOrders     WarehousePurchaseOrder[]   @relation("WarehousePurchaseOrderCreator")
  auditEvents                 AuditEvent[]               @relation("UserAuditEvents")
  printCalculations           PrintCalculation[]
}

model Session {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     Int
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  ipHash     String?
  userAgent  String?

  @@index([expiresAt])
  @@index([userId])
}

model AuditEvent {
  id          String   @id @default(uuid())
  actorUserId Int?
  action      String
  target      String?
  metadata    String?
  createdAt   DateTime @default(now())
  actor       User?    @relation("UserAuditEvents", fields: [actorUserId], references: [id])

  @@index([createdAt])
}

model Article {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  excerpt    String?
  content    String
  coverImage String?
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  authorId   Int
  author     User     @relation(fields: [authorId], references: [id])
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  rating    Int
  text      String
  photos    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Order {
  id                Int                @id @default(autoincrement())
  userId            Int
  status            String             @default("pending")
  details           String?
  price             Float?
  createdAt         DateTime           @default(now())
  assignedToId      Int?
  deadline          DateTime?
  title             String?
  updatedAt         DateTime           @default(now()) @updatedAt
  chat              ChatSession?
  assignedTo        User?              @relation("OrderAssignee", fields: [assignedToId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  comments          OrderComment[]
  shopWarehouseLogs ShopWarehouseLog[]
}

model PrintCalculation {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           Int
  createdAt        DateTime @default(now())
  mode             String
  tech             String
  material         String
  count            Int      @default(1)
  fileName         String?
  fileSize         Int?
  manualWeightGrams Int?
  manualTimeHours  Float?
  minPriceRub      Int
  maxPriceRub      Int
  input            String?

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model OrderComment {
  id        Int      @id @default(autoincrement())
  orderId   Int
  userId    Int
  text      String
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model ChatSession {
  id        Int           @id @default(autoincrement())
  userId    Int
  orderId   Int?          @unique
  status    String        @default("active")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  order     Order?        @relation(fields: [orderId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id          Int         @id @default(autoincrement())
  sessionId   Int
  senderId    Int?
  content     String
  isInternal  Boolean     @default(false)
  attachments String?
  read        Boolean     @default(false)
  createdAt   DateTime    @default(now())
  sender      User?       @relation(fields: [senderId], references: [id])
  session     ChatSession @relation(fields: [sessionId], references: [id])
}

model TelegramSubscriber {
  id        Int      @id @default(autoincrement())
  chatId    String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model MaxSubscriber {
  id        Int      @id @default(autoincrement())
  chatId    String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model ShopCategory {
  id        Int            @id @default(autoincrement())
  name      String
  slug      String         @unique
  parentId  Int?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @default(now()) @updatedAt
  parent    ShopCategory?  @relation("ShopCategoryParent", fields: [parentId], references: [id])
  children  ShopCategory[] @relation("ShopCategoryParent")
  products  ShopProduct[]

  @@index([parentId])
}

model ShopProduct {
  id                  Int                              @id @default(autoincrement())
  name                String
  slug                String                           @unique
  sku                 String?
  description         String?
  shortDescription    String?
  priceKopeks         Int
  compareAtKopeks     Int?
  stock               Int                              @default(0)
  isActive            Boolean                          @default(true)
  categoryId          Int?
  createdAt           DateTime                         @default(now())
  updatedAt           DateTime                         @default(now()) @updatedAt
  purchasePriceKopeks Int?
  allowPreorder       Boolean                          @default(false)
  itemType            String                           @default("product")
  weightGrams         Int?
  lengthMm            Int?
  widthMm             Int?
  heightMm            Int?
  cartItems           ShopCartItem[]
  clientLogs          ShopClientLog[]
  inventoryItems      ShopInventoryItem[]
  orderItems          ShopOrderItem[]
  category            ShopCategory?                    @relation(fields: [categoryId], references: [id])
  images              ShopProductImage[]
  warehouseLogs       ShopWarehouseLog[]
  wishlistItems       ShopWishlistItem[]
  inventoryCountItems WarehouseInventoryCountItem[]
  locationStocks      WarehouseLocationStock[]
  productionConsumes  WarehouseProductionConsumeItem[] @relation("WarehouseProductionMaterial")
  productionOrders    WarehouseProductionOrder[]
  receiptItems        WarehouseReceiptItem[]
  recipes             WarehouseRecipe?
  recipeMaterials     WarehouseRecipeItem[]            @relation("WarehouseRecipeMaterial")
  transferItems       WarehouseTransferItem[]
  purchaseOrderItems  WarehousePurchaseOrderItem[]

  @@index([isActive, priceKopeks])
  @@index([categoryId])
  @@index([itemType])
}

model ShopProductImage {
  id        Int         @id @default(autoincrement())
  productId Int
  url       String
  alt       String?
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  product   ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ShopWishlistItem {
  id        Int         @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime    @default(now())
  product   ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model ShopCart {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    Int            @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @default(now()) @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ShopCartItem[]
}

model ShopCartItem {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId          String      @db.Uuid
  productId       Int
  quantity        Int         @default(1)
  unitPriceKopeks Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @default(now()) @updatedAt
  cart            ShopCart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product         ShopProduct @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([productId])
}

model ShopOrder {
  id                      String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNo                 Int                @unique @default(autoincrement())
  userId                  Int?
  status                  String             @default("pending")
  paymentStatus           String             @default("unpaid")
  paymentProvider         String?
  shippingMethod          String             @default("pickup")
  shippingCostKopeks      Int                @default(0)
  totalKopeks             Int                @default(0)
  contactName             String?
  contactPhone            String?
  contactEmail            String?
  deliveryCity            String?
  deliveryAddress         String?
  deliveryPostalCode      String?
  comment                 String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @default(now()) @updatedAt
  deliveryPhone           String?
  shippingCarrier         String?
  shippingTrackingNo      String?
  shippingStatus          String             @default("new")
  shippingCostFinalKopeks Int?
  shippingQuoteMinKopeks  Int?
  shippingQuoteMaxKopeks  Int?
  publicAccessToken       String?            @unique
  cashEntries             CashEntry[]
  clientLogs              ShopClientLog[]
  user                    User?              @relation(fields: [userId], references: [id])
  items                   ShopOrderItem[]
  payments                ShopPayment[]
  warehouseLogs           ShopWarehouseLog[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ShopOrderItem {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String       @db.Uuid
  productId       Int?
  productName     String
  sku             String?
  quantity        Int
  unitPriceKopeks Int
  totalKopeks     Int
  createdAt       DateTime     @default(now())
  order           ShopOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         ShopProduct? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model ShopPayment {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId           String     @db.Uuid
  provider          String
  status            String     @default("pending")
  amountKopeks      Int
  currency          String     @default("RUB")
  externalPaymentId String?
  paymentUrl        String?
  rawPayload        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @default(now()) @updatedAt
  CashEntry         CashEntry?
  order             ShopOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([provider, status, createdAt])
  @@index([externalPaymentId])
}

model ShopInventoryItem {
  id                         Int                @id @default(autoincrement())
  productId                  Int
  unit                       String             @default("pcs")
  quantity                   Decimal            @default(0) @db.Decimal(18, 3)
  minThreshold               Decimal            @default(0) @db.Decimal(18, 3)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @default(now()) @updatedAt
  lastPurchaseUnitCostKopeks Int?
  reserved                   Decimal            @default(0) @db.Decimal(18, 3)
  warehouseId                Int                @default(1)
  locationId                 Int?
  location                   WarehouseLocation? @relation(fields: [locationId], references: [id])
  product                    ShopProduct        @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse                  Warehouse          @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([unit])
  @@index([quantity])
  @@index([warehouseId])
}

model ShopWarehouseLog {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt       DateTime           @default(now())
  actorUserId     Int?
  actorRole       String?
  actionType      String
  reason          String?
  productId       Int?
  sku             String?
  productName     String?
  quantityDelta   Decimal            @db.Decimal(18, 3)
  unit            String
  shopOrderId     String?            @db.Uuid
  serviceOrderId  Int?
  supplier        String?
  documentNo      String?
  comment         String?
  ipHash          String?
  userAgent       String?
  unitCostKopeks  Int?
  totalCostKopeks Int?
  warehouseId     Int?               @default(1)
  locationId      Int?
  cashEntries     CashEntry[]
  actor           User?              @relation(fields: [actorUserId], references: [id])
  location        WarehouseLocation? @relation(fields: [locationId], references: [id])
  product         ShopProduct?       @relation(fields: [productId], references: [id])
  serviceOrder    Order?             @relation(fields: [serviceOrderId], references: [id])
  shopOrder       ShopOrder?         @relation(fields: [shopOrderId], references: [id])
  warehouse       Warehouse?         @relation(fields: [warehouseId], references: [id])

  @@index([createdAt])
  @@index([actorRole, createdAt])
  @@index([actionType, createdAt])
  @@index([productId, createdAt])
  @@index([shopOrderId])
}

model ShopClientLog {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime     @default(now())
  userId      Int?
  actionType  String
  productId   Int?
  shopOrderId String?      @db.Uuid
  quantity    Decimal?     @db.Decimal(18, 3)
  unit        String?
  orderStatus String?
  ipHash      String?
  userAgent   String?
  message     String?
  product     ShopProduct? @relation(fields: [productId], references: [id])
  shopOrder   ShopOrder?   @relation(fields: [shopOrderId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([actionType, createdAt])
  @@index([userId, createdAt])
  @@index([productId, createdAt])
  @@index([shopOrderId, createdAt])
}

model Warehouse {
  id               Int                        @id @default(autoincrement())
  code             String                     @unique
  name             String
  isActive         Boolean                    @default(true)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @default(now()) @updatedAt
  inventory        ShopInventoryItem[]
  logs             ShopWarehouseLog[]
  inventoryCounts  WarehouseInventoryCount[]
  locations        WarehouseLocation[]
  locationStocks   WarehouseLocationStock[]
  productionOrders WarehouseProductionOrder[]
  receipts         WarehouseReceipt[]
  transfersFrom    WarehouseTransfer[]        @relation("WarehouseTransferFromWarehouse")
  transfersTo      WarehouseTransfer[]        @relation("WarehouseTransferToWarehouse")
}

model WarehouseLocation {
  id            Int                      @id @default(autoincrement())
  warehouseId   Int
  code          String
  name          String
  isActive      Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @default(now()) @updatedAt
  inventory     ShopInventoryItem[]
  logs          ShopWarehouseLog[]
  warehouse     Warehouse                @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stocks        WarehouseLocationStock[]
  receipts      WarehouseReceipt[]
  transfersFrom WarehouseTransfer[]      @relation("WarehouseTransferFromLocation")
  transfersTo   WarehouseTransfer[]      @relation("WarehouseTransferToLocation")

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

model WarehouseLocationStock {
  id          Int               @id @default(autoincrement())
  warehouseId Int
  locationId  Int
  productId   Int
  unit        String
  quantity    Decimal           @default(0) @db.Decimal(18, 3)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now()) @updatedAt
  location    WarehouseLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product     ShopProduct       @relation(fields: [productId], references: [id])
  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, locationId, productId])
  @@index([warehouseId, locationId])
  @@index([productId])
}

model WarehouseSupplier {
  id             Int                @id @default(autoincrement())
  name           String             @unique
  contact        String?
  phone          String?
  email          String?
  address        String?
  inn            String?
  kpp            String?
  bankAccount    String?
  contractNumber String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @default(now()) @updatedAt
  receipts       WarehouseReceipt[]
  purchaseOrders WarehousePurchaseOrder[]
}

model WarehouseReceipt {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId      Int?
  documentNo      String
  receivedAt      DateTime               @default(now())
  status          String                 @default("draft")
  attachmentUrl   String?
  comment         String?
  currency        String                 @default("RUB")
  createdByUserId Int?
  postedAt        DateTime?
  postedByUserId  Int?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @default(now()) @updatedAt
  warehouseId     Int                    @default(1)
  locationId      Int?
  createdBy       User?                  @relation("WarehouseReceiptCreator", fields: [createdByUserId], references: [id])
  location        WarehouseLocation?     @relation(fields: [locationId], references: [id])
  postedBy        User?                  @relation("WarehouseReceiptPoster", fields: [postedByUserId], references: [id])
  supplier        WarehouseSupplier?     @relation(fields: [supplierId], references: [id])
  warehouse       Warehouse              @relation(fields: [warehouseId], references: [id])
  purchaseOrderId String?                @db.Uuid
  purchaseOrder   WarehousePurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  items           WarehouseReceiptItem[]

  @@index([receivedAt])
  @@index([status, receivedAt])
  @@index([supplierId, receivedAt])
  @@index([warehouseId, receivedAt])
}

model WarehouseTransfer {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromWarehouseId Int
  fromLocationId  Int?
  toWarehouseId   Int
  toLocationId    Int?
  status          String                  @default("draft")
  comment         String?
  createdByUserId Int?
  postedAt        DateTime?
  postedByUserId  Int?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @default(now()) @updatedAt
  createdBy       User?                   @relation("WarehouseTransferCreator", fields: [createdByUserId], references: [id])
  fromLocation    WarehouseLocation?      @relation("WarehouseTransferFromLocation", fields: [fromLocationId], references: [id])
  fromWarehouse   Warehouse               @relation("WarehouseTransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  postedBy        User?                   @relation("WarehouseTransferPoster", fields: [postedByUserId], references: [id])
  toLocation      WarehouseLocation?      @relation("WarehouseTransferToLocation", fields: [toLocationId], references: [id])
  toWarehouse     Warehouse               @relation("WarehouseTransferToWarehouse", fields: [toWarehouseId], references: [id])
  items           WarehouseTransferItem[]

  @@index([status, createdAt])
  @@index([fromWarehouseId, createdAt])
  @@index([toWarehouseId, createdAt])
}

model WarehouseTransferItem {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transferId  String            @db.Uuid
  productId   Int
  sku         String?
  productName String
  quantity    Decimal           @db.Decimal(18, 3)
  unit        String
  createdAt   DateTime          @default(now())
  product     ShopProduct       @relation(fields: [productId], references: [id])
  transfer    WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@index([productId])
}

model WarehouseReceiptItem {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receiptId       String           @db.Uuid
  productId       Int?
  sku             String?
  productName     String
  quantity        Decimal          @db.Decimal(18, 3)
  unit            String
  unitCostKopeks  Int
  totalCostKopeks Int
  createdAt       DateTime         @default(now())
  product         ShopProduct?     @relation(fields: [productId], references: [id])
  receipt         WarehouseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@index([productId])
}

model WarehouseRecipe {
  id        String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId Int                   @unique
  version   Int                   @default(1)
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @default(now()) @updatedAt
  product   ShopProduct           @relation(fields: [productId], references: [id], onDelete: Cascade)
  items     WarehouseRecipeItem[]
}

model WarehouseRecipeItem {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipeId          String          @db.Uuid
  materialProductId Int
  quantity          Decimal         @db.Decimal(18, 3)
  unit              String
  createdAt         DateTime        @default(now())
  material          ShopProduct     @relation("WarehouseRecipeMaterial", fields: [materialProductId], references: [id])
  recipe            WarehouseRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([materialProductId])
}

model WarehouseProductionOrder {
  id              String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  warehouseId     Int
  productId       Int
  quantity        Decimal                          @db.Decimal(18, 3)
  unit            String
  status          String                           @default("draft")
  comment         String?
  createdByUserId Int?
  postedAt        DateTime?
  postedByUserId  Int?
  createdAt       DateTime                         @default(now())
  updatedAt       DateTime                         @default(now()) @updatedAt
  consumes        WarehouseProductionConsumeItem[]
  createdBy       User?                            @relation("WarehouseProductionCreator", fields: [createdByUserId], references: [id])
  postedBy        User?                            @relation("WarehouseProductionPoster", fields: [postedByUserId], references: [id])
  product         ShopProduct                      @relation(fields: [productId], references: [id])
  warehouse       Warehouse                        @relation(fields: [warehouseId], references: [id])

  @@index([warehouseId, createdAt])
  @@index([status, createdAt])
}

model WarehouseProductionConsumeItem {
  id                String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productionId      String                   @db.Uuid
  materialProductId Int
  quantity          Decimal                  @db.Decimal(18, 3)
  unit              String
  unitCostKopeks    Int?
  totalCostKopeks   Int?
  createdAt         DateTime                 @default(now())
  material          ShopProduct              @relation("WarehouseProductionMaterial", fields: [materialProductId], references: [id])
  production        WarehouseProductionOrder @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@index([productionId])
  @@index([materialProductId])
}

model WarehouseInventoryCount {
  id              String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  warehouseId     Int
  status          String                        @default("draft")
  comment         String?
  startedAt       DateTime                      @default(now())
  createdByUserId Int?
  postedAt        DateTime?
  postedByUserId  Int?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @default(now()) @updatedAt
  createdBy       User?                         @relation("WarehouseInventoryCreator", fields: [createdByUserId], references: [id])
  postedBy        User?                         @relation("WarehouseInventoryPoster", fields: [postedByUserId], references: [id])
  warehouse       Warehouse                     @relation(fields: [warehouseId], references: [id])
  items           WarehouseInventoryCountItem[]

  @@index([warehouseId, startedAt])
  @@index([status, startedAt])
}

model WarehouseInventoryCountItem {
  id          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inventoryId String                  @db.Uuid
  productId   Int
  expectedQty Decimal                 @db.Decimal(18, 3)
  countedQty  Decimal                 @db.Decimal(18, 3)
  delta       Decimal                 @db.Decimal(18, 3)
  unit        String
  createdAt   DateTime                @default(now())
  inventory   WarehouseInventoryCount @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  product     ShopProduct             @relation(fields: [productId], references: [id])

  @@unique([inventoryId, productId])
  @@index([inventoryId])
  @@index([productId])
}

model Permission {
  key              String                  @id
  description      String?
  groupPermissions AccessGroupPermission[]
  rolePermissions  RolePermission[]
  userPermissions  UserAccessPermission[]
}

model RolePermission {
  id            Int        @id @default(autoincrement())
  roleName      String
  permissionKey String
  createdAt     DateTime   @default(now())
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@unique([roleName, permissionKey])
  @@index([roleName])
}

model AccessGroup {
  id              Int                     @id @default(autoincrement())
  name            String                  @unique
  description     String?
  createdByUserId Int?
  createdAt       DateTime                @default(now())
  createdBy       User?                   @relation("AccessGroupCreator", fields: [createdByUserId], references: [id])
  permissions     AccessGroupPermission[]
  members         UserAccessGroup[]
}

model AccessGroupPermission {
  id            Int         @id @default(autoincrement())
  groupId       Int
  permissionKey String
  createdAt     DateTime    @default(now())
  group         AccessGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permission    Permission  @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@unique([groupId, permissionKey])
  @@index([permissionKey])
}

model UserAccessGroup {
  id        Int         @id @default(autoincrement())
  userId    Int
  groupId   Int
  createdAt DateTime    @default(now())
  group     AccessGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

model UserAccessPermission {
  id            Int        @id @default(autoincrement())
  userId        Int
  permissionKey String
  allow         Boolean    @default(true)
  createdAt     DateTime   @default(now())
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionKey])
  @@index([permissionKey, allow])
}

model CashAccount {
  id              Int                  @id @default(autoincrement())
  code            String               @unique
  name            String
  type            String
  currency        String               @default("RUB")
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @default(now()) @updatedAt
  entries         CashEntry[]
  reconciliations CashReconciliation[]
}

model CashEntry {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId       Int
  direction       String
  entryType       String
  amountKopeks    Int
  currency        String            @default("RUB")
  description     String?
  status          String            @default("confirmed")
  shopOrderId     String?           @db.Uuid
  shopPaymentId   String?           @unique @db.Uuid
  warehouseLogId  String?           @db.Uuid
  createdByUserId Int?
  ipHash          String?
  userAgent       String?
  createdAt       DateTime          @default(now())
  account         CashAccount       @relation(fields: [accountId], references: [id])
  createdBy       User?             @relation(fields: [createdByUserId], references: [id])
  shopOrder       ShopOrder?        @relation(fields: [shopOrderId], references: [id])
  ShopPayment     ShopPayment?      @relation(fields: [shopPaymentId], references: [id])
  warehouseLog    ShopWarehouseLog? @relation(fields: [warehouseLogId], references: [id])

  @@index([createdAt])
  @@index([accountId, createdAt])
  @@index([direction, createdAt])
  @@index([entryType, createdAt])
  @@index([shopOrderId])
}

model CashReconciliation {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId       Int
  day             DateTime
  openingKopeks   Int         @default(0)
  expectedKopeks  Int
  actualKopeks    Int?
  diffKopeks      Int?
  createdByUserId Int?
  note            String?
  createdAt       DateTime    @default(now())
  cutoffAt        DateTime    @default(now())
  status          String      @default("pending")
  account         CashAccount @relation(fields: [accountId], references: [id])
  createdBy       User?       @relation(fields: [createdByUserId], references: [id])

  @@unique([accountId, day])
  @@index([day])
}

model WarehousePurchaseOrder {
  id              String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierId      Int
  orderNo         String                     @unique
  status          String                     @default("pending") // pending, partially_received, completed, cancelled
  totalKopeks     Int
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @default(now()) @updatedAt
  createdByUserId Int?
  comment         String?
  
  supplier        WarehouseSupplier          @relation(fields: [supplierId], references: [id])
  createdBy       User?                      @relation("WarehousePurchaseOrderCreator", fields: [createdByUserId], references: [id])
  items           WarehousePurchaseOrderItem[]
  receipts        WarehouseReceipt[]

  @@index([supplierId])
  @@index([status])
}

model WarehousePurchaseOrderItem {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId String                 @db.Uuid
  productId       Int?
  sku             String?
  productName     String
  quantity        Decimal                @db.Decimal(18, 3)
  receivedQuantity Decimal               @default(0) @db.Decimal(18, 3)
  unit            String
  unitPriceKopeks Int
  
  purchaseOrder   WarehousePurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         ShopProduct?           @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
}
